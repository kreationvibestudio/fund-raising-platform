# Required for inline checkout (pk_live_… or pk_test_…). On Render, set before build or redeploy with Clear build cache.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Optional: only if you use a Paystack Payment Page — must include /pay/ (never use bare https://paystack.com).
NEXT_PUBLIC_PAYSTACK_DONATE_URL=https://paystack.com/pay/your-payment-link
NEXT_PUBLIC_CAMPAIGN_URL=https://your-campaign-link.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
CAMPAIGN_NAME=Fund Raising Campaign
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Required for POST /api/donations with source=manual (offline/bank). Use a long random string; never commit the real value.
# On Render use this exact name (Linux is case-sensitive). Alias: admin_manual_secret.
ADMIN_MANUAL_SECRET=your-long-random-admin-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=Campaign Team <no-reply@yourdomain.com>
